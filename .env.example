# ============================================================
# ZTE Titan Manager - Configurações de Ambiente
# Copie este arquivo para .env e ajuste os valores
# ============================================================

# Chave secreta para JWT (MUDE ISSO EM PRODUÇÃO!)
SECRET_KEY=zte-titan-super-secret-key-change-in-production-2024

# Banco de dados (SQLite local)
DATABASE_URL=sqlite:////app/data/zte_titan.db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Cache TTL em segundos (86400 = 24 horas)
CACHE_TTL=86400

# Sessão JWT em minutos (480 = 8 horas)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Timeouts SSH em segundos
SSH_TIMEOUT=30
SSH_COMMAND_TIMEOUT=60
